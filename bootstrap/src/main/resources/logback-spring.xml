<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="happygallery"/>
    <springProperty scope="context" name="ROOT_LOG_LEVEL" source="logging.level.root" defaultValue="INFO"/>

    <springProfile name="prod">
        <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp>
                        <timeZone>Asia/Seoul</timeZone>
                    </timestamp>
                    <logLevel/>
                    <loggerName/>
                    <threadName/>
                    <provider class="com.personal.happygallery.bootstrap.logging.MaskingMessageJsonProvider"/>
                    <mdc/>
                    <stackTrace/>
                    <pattern>
                        <pattern>{"service":"${APP_NAME}"}</pattern>
                    </pattern>
                </providers>
            </encoder>
        </appender>

        <root level="${ROOT_LOG_LEVEL}">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>

    <springProfile name="!prod">
        <appender name="CONSOLE_TEXT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
                <layout class="com.personal.happygallery.bootstrap.logging.MaskingPatternLayout">
                    <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %5p [%X{requestId:-}] %logger{36} - %msg%n%ex</pattern>
                </layout>
            </encoder>
        </appender>

        <root level="${ROOT_LOG_LEVEL}">
            <appender-ref ref="CONSOLE_TEXT"/>
        </root>
    </springProfile>
</configuration>
