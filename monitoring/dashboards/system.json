{
  "uid": "happygallery-system",
  "title": "happyGallery — System",
  "tags": ["happygallery", "system"],
  "timezone": "Asia/Seoul",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (5m avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"happygallery\"}[5m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Response Time p95 (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"happygallery\"}[5m]))",
          "legendFormat": "{{method}} {{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP 5xx Rate (5m avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"happygallery\",status=~\"5..\"}[5m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"happygallery\",area=\"heap\"}",
          "legendFormat": "{{id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5,
      "title": "JVM GC Pause (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"happygallery\"}[5m])",
          "legendFormat": "{{action}} {{cause}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "title": "HikariCP Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"happygallery\"}",
          "legendFormat": "active"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"happygallery\"}",
          "legendFormat": "idle"
        },
        {
          "expr": "hikaricp_connections_max{application=\"happygallery\"}",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 7,
      "title": "Tomcat Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "tomcat_threads_current_threads{application=\"happygallery\"}",
          "legendFormat": "current"
        },
        {
          "expr": "tomcat_threads_busy_threads{application=\"happygallery\"}",
          "legendFormat": "busy"
        },
        {
          "expr": "tomcat_threads_config_max_threads{application=\"happygallery\"}",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 8,
      "title": "Notification Executor Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "executor_active_threads{application=\"happygallery\",name=\"notificationExecutor\"}",
          "legendFormat": "active"
        },
        {
          "expr": "executor_pool_size_threads{application=\"happygallery\",name=\"notificationExecutor\"}",
          "legendFormat": "pool size"
        },
        {
          "expr": "executor_pool_max_threads{application=\"happygallery\",name=\"notificationExecutor\"}",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 9,
      "title": "Payment Timeout Executor Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "executor_active_threads{application=\"happygallery\",name=\"paymentTimeoutExecutor\"}",
          "legendFormat": "active"
        },
        {
          "expr": "executor_pool_size_threads{application=\"happygallery\",name=\"paymentTimeoutExecutor\"}",
          "legendFormat": "pool size"
        },
        {
          "expr": "executor_pool_max_threads{application=\"happygallery\",name=\"paymentTimeoutExecutor\"}",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 10,
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"happygallery\"}",
          "legendFormat": "live"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"happygallery\"}",
          "legendFormat": "peak"
        }
      ]
    },
    {
      "id": 11,
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"happygallery\"}",
          "legendFormat": "app"
        },
        {
          "expr": "system_cpu_usage{application=\"happygallery\"}",
          "legendFormat": "system"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    }
  ],
  "schemaVersion": 39
}
